# Database (Neon / Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Production: https://your-domain.vercel.app  — Local: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth: https://github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# OpenAI (optional — app falls back to simulated mentor/feedback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Vercel Blob — create token in Vercel Blob store; omit locally to use data-URL fallback uploads
BLOB_READ_WRITE_TOKEN=
